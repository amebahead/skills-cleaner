{
  "name": "skills-cleaner",
  "description": "Compare installed skills for similarity, identify overlapping functionality, and interactively clean up redundant skills. Track skill usage statistics.",
  "version": "1.1.0",
  "author": {
    "name": "amebahead",
    "email": "dowitcher@naver.com"
  },
  "homepage": "https://github.com/amebahead/skills-cleaner",
  "repository": "https://github.com/amebahead/skills-cleaner",
  "license": "MIT",
  "keywords": ["skills", "cleanup", "similarity", "duplicates", "organization", "list", "search", "profile", "usage", "tracking"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/track-skill.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/track-skill-prompt.sh"
          }
        ]
      }
    ]
  }
}
